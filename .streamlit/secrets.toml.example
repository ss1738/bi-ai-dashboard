# Copy this file to .streamlit/secrets.toml (gitignored) and paste your OWN key.
# It stays on your machine and is NEVER committed.
# For the LIVE app, put the same key in Streamlit Cloud -> Settings -> Secrets.
# Rotate any key that has ever been exposed before using it.

# Fill in ONE, matching the provider you pick in the app's sidebar:
GROQ_API_KEY = "gsk_..."       # free at console.groq.com
# OPENAI_API_KEY = "sk-..."
# XAI_API_KEY = "xai-..."      # for Grok; create/rotate at console.x.ai
