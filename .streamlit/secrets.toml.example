# Copy this file to .streamlit/secrets.toml and paste your OWN rotated key.
# .streamlit/secrets.toml is gitignored, so it will NEVER be committed.
# For the LIVE app, put the same key in Streamlit Cloud -> Settings -> Secrets instead.
GROQ_API_KEY = "gsk_paste_your_rotated_key_here"
